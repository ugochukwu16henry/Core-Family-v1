@page "/finance"
@inject CoreFamily.Admin.Services.AdminApiClient AdminApi

<PageTitle>Finance</PageTitle>

<h1>Finance Operations</h1>
<p>Review transactions, inspect refund requests, and issue refunds from the admin dashboard.</p>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <p class="error-text">@errorMessage</p>
}

<button class="btn btn-primary" @onclick="LoadTransactionsAsync" disabled="@isLoading">@(isLoading ? "Loading..." :
        "Load Transactions")</button>

    @if (transactions.Count > 0)
    {
        <div class="admin-grid">
            @foreach (var transaction in transactions)
            {
                <article class="admin-card">
                    <h3>@transaction.Type • @transaction.Amount @transaction.Currency</h3>
                    <p><strong>User:</strong> @transaction.UserEmail</p>
                    <p><strong>Method:</strong> @transaction.PaymentMethod</p>
                    <p><strong>Status:</strong> @transaction.Status</p>
                    <p><strong>Created:</strong> @transaction.CreatedAt.ToString("g")</p>
                    <p><strong>Notes:</strong> @(string.IsNullOrWhiteSpace(transaction.FailureReason) ? "None" :
                                    transaction.FailureReason)</p>

                        @if (transaction.Status == "Completed")
                        {
                            <div class="refund-box">
                                <textarea placeholder="Refund reason" @bind="refundReasons[transaction.Id]"></textarea>
                                <button class="btn btn-secondary" @onclick="() => RefundAsync(transaction.Id)">Issue Refund</button>
                            </div>
                        }
                    </article>
                }
            </div>
        }

@code {
    private readonly List<CoreFamily.Admin.Models.AdminTransactionSummary> transactions = [];
    private readonly Dictionary<Guid, string> refundReasons = [];
    private bool isLoading;
    private string? errorMessage;

    private async Task LoadTransactionsAsync()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            transactions.Clear();
            transactions.AddRange(await AdminApi.GetTransactionsAsync());
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RefundAsync(Guid transactionId)
    {
        try
        {
            errorMessage = null;
            var reason = refundReasons.TryGetValue(transactionId, out var value) ? value : string.Empty;
            var updated = await AdminApi.RefundTransactionAsync(transactionId, reason);
            if (updated is null)
                return;

            var index = transactions.FindIndex(t => t.Id == transactionId);
            if (index >= 0)
                transactions[index] = updated;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
}
