@page "/"
@inject CoreFamily.Admin.Services.AdminApiClient AdminApi

<PageTitle>Home</PageTitle>

<h1>Core Family Admin</h1>

<p>Paste an admin or moderator JWT from the API login flow to use moderation tools in this dashboard.</p>

<div class="token-panel">
    <label for="token-input"><strong>Admin JWT</strong></label>
    <textarea id="token-input" class="token-input" @bind="token"></textarea>
    <button class="btn btn-primary" @onclick="SaveToken">Save Token</button>
    @if (!string.IsNullOrWhiteSpace(savedMessage))
    {
        <p>@savedMessage</p>
    }
    <ol>
        <li>Login via the Core Family API using an Admin or Moderator account.</li>
        <li>Paste the returned access token here.</li>
        <li>Open User Moderation or Flagged Reviews from the left menu.</li>
    </ol>
</div>

@code {
    private string token = string.Empty;
    private string? savedMessage;

    protected override void OnInitialized()
    {
        token = AdminApi.GetToken();
    }

    private void SaveToken()
    {
        AdminApi.SetToken(token);
        savedMessage = string.IsNullOrWhiteSpace(token)
            ? "Token cleared."
            : "Token saved for this admin session.";
    }
}
