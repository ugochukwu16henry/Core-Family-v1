# Core Family local environment variables
# This file is git-ignored. Keep real secrets here only.

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development

# PostgreSQL (local docker default)
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=corefamilydb;Username=corefamily;Password=CoreFamily@Dev2026
DATABASE_URL=postgresql://corefamily:CoreFamily%40Dev2026@localhost:5432/corefamilydb
ConnectionStrings__Redis=localhost:6379

# JWT
Jwt__Key=CoreFamilyDevelopmentJwtKey-Replace-In-Production-Min32Chars!
Jwt__Issuer=https://api.corefamily.com
Jwt__Audience=https://corefamily.com
Jwt__ExpiryMinutes=60
Jwt__RefreshExpiryDays=7

# Frontend API endpoint reference
# Angular still uses src/environments/environment*.ts by default.
CORE_FAMILY_API_URL=http://localhost:5000/api/v1

# Payment gateway checkout base URLs (used when successUrl is not explicitly provided)
Stripe__CheckoutBaseUrl=https://checkout.stripe.com/pay
Stripe__ApiBaseUrl=https://api.stripe.com
Stripe__DefaultSuccessUrl=http://localhost:4200/sessions
Stripe__DefaultCancelUrl=http://localhost:4200/sessions
Paystack__CheckoutBaseUrl=https://checkout.paystack.com
Paystack__ApiBaseUrl=https://api.paystack.co
Paystack__DefaultCallbackUrl=http://localhost:4200/sessions
GooglePay__CheckoutBaseUrl=https://pay.google.com/gp/p/ui/pay
